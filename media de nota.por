programa {
  funcao inicio() {
    real ativ1, ativ2, ativ3, media
        escreva ("Digite a nota da atividade 1°: ")
        leia (ativ1)

        escreva ("Digite a nota da atividade n° 2: ")
        leia (ativ2)

        escreva ("Digite a nota da atividade n° 3: ")
        leia (ativ3)

        media = ativ1 + ativ2 + ativ3 / 3

        escreva ("A media é: ", media)


  }
}
